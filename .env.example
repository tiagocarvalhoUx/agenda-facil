# =====================================================================
# Frontend (Vite) — EXPOSTO AO BROWSER. Apenas chaves públicas aqui.
# NUNCA coloque service_role nem segredos de provedor neste arquivo.
# =====================================================================
VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Meta Pixel (rastreamento Facebook/Instagram Ads). ID numérico do pixel.
VITE_META_PIXEL_ID="000000000000000"

# Web Push — chave VAPID PÚBLICA (exposta ao browser, ok). Gere o par com
# `npx web-push generate-vapid-keys`. A PRIVADA vai nos secrets do servidor.
VITE_VAPID_PUBLIC_KEY="Bxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# =====================================================================
# Edge Functions / servidor — NÃO são lidos pelo frontend.
# Configurados via `supabase secrets set ...` (nunca commitados).
# Listados aqui só como documentação do que o servidor precisa.
# =====================================================================
# SUPABASE_SERVICE_ROLE_KEY="server-only-never-in-frontend"
# RESEND_API_KEY="re_..."
# REMINDER_FROM_EMAIL="lembretes@seu-dominio.com"
#
# Pagamento (Edge Function `payments`) — configurar via `supabase secrets set`.
# PAYMENT_PROVIDER="asaas"               # provedor ativo (plugável)
# ASAAS_API_KEY="$aact_..."              # API key do painel Asaas (server-only!)
# ASAAS_ENV="sandbox"                    # "sandbox" p/ testes | "production" p/ valer
# ASAAS_WEBHOOK_TOKEN="um-token-secreto" # mesmo valor no webhook do painel Asaas
#
# Meta Conversions API (Subscribe server-side, disparado no webhook de pagamento).
# META_PIXEL_ID="2475814112935394"       # mesmo id do Pixel do site (VITE_META_PIXEL_ID)
# META_CAPI_TOKEN="EAAG..."              # Gerenciador de Eventos → Config. → Gerar token
#
# Web Push (Edge Function `notify-booking`) — configurar via `supabase secrets set`.
# VAPID_PUBLIC_KEY="B..."                # mesma chave pública do VITE_VAPID_PUBLIC_KEY
# VAPID_PRIVATE_KEY="..."                # PRIVADA (server-only!) — nunca no frontend
# VAPID_SUBJECT="mailto:voce@dominio.com"# contato técnico exigido pelo padrão VAPID
# NOTIFY_SECRET="um-segredo-aleatorio"   # mesmo valor inserido em private_notify_config
