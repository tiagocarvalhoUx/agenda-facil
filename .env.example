# =====================================================================
# Frontend (Vite) — EXPOSTO AO BROWSER. Apenas chaves públicas aqui.
# NUNCA coloque service_role nem segredos de provedor neste arquivo.
# =====================================================================
VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# =====================================================================
# Edge Functions / servidor — NÃO são lidos pelo frontend.
# Configurados via `supabase secrets set ...` (nunca commitados).
# Listados aqui só como documentação do que o servidor precisa.
# =====================================================================
# SUPABASE_SERVICE_ROLE_KEY="server-only-never-in-frontend"
# RESEND_API_KEY="re_..."
# REMINDER_FROM_EMAIL="lembretes@seu-dominio.com"
