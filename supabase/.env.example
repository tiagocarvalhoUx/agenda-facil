# Variáveis lidas pelo Supabase CLI ao subir o stack LOCAL (`supabase start`).
# O config.toml referencia estes nomes via env(...). NÃO commite o .env real
# (só este .example). Copie para `supabase/.env` e preencha com valores reais.
#
# Login Google — credenciais do Google Cloud Console (OAuth 2.0 Client ID).
# Em PRODUÇÃO estes valores vão no painel Supabase, não aqui.
SUPABASE_AUTH_GOOGLE_CLIENT_ID="seu-client-id.apps.googleusercontent.com"
SUPABASE_AUTH_GOOGLE_SECRET="seu-client-secret"
